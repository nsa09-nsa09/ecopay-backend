# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (used by postgres container and backend)
POSTGRES_DB=ecopay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Datasource (backend -> postgres). Host must be the compose service name: "postgres"
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ecopay
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# Flyway uses the same DB credentials
SPRING_FLYWAY_URL=jdbc:postgresql://postgres:5432/ecopay
SPRING_FLYWAY_USER=postgres
SPRING_FLYWAY_PASSWORD=change-me

# JWT (min 32 chars, generate with: openssl rand -base64 48)
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Field-level encryption for TELECOM identifiers (32 bytes base64, generate with: openssl rand -base64 32)
APP_SECURITY_FIELD_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# CORS allowed origins (comma-separated). Frontend dev server + prod domain.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting
APP_RATE_LIMIT_LOGIN_ATTEMPTS=5
APP_RATE_LIMIT_LOGIN_DURATION_MINUTES=15

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
