# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL — single source of truth for both postgres container and backend
POSTGRES_DB=ecopay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
# POSTGRES_HOST defaults to "postgres" (compose service name). Override only if using external DB.
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# Host port mapping for local docker-compose (not used in Dokploy)
POSTGRES_PORT_HOST=5432

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Field-level encryption for TELECOM identifiers (generate with: openssl rand -base64 32)
APP_SECURITY_FIELD_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# CORS allowed origins (comma-separated, no trailing slash)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting
APP_RATE_LIMIT_LOGIN_ATTEMPTS=5
APP_RATE_LIMIT_LOGIN_DURATION_MINUTES=15

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Freedom Pay (Kazakhstan payment gateway)
# Sandbox: https://test-api.freedompay.kz  |  Production: https://api.freedompay.kz
FREEDOMPAY_BASE_URL=https://test-api.freedompay.kz
FREEDOMPAY_MERCHANT_ID=
FREEDOMPAY_SECRET_KEY=
# Separate secret for payouts API (if Freedom Pay payouts contract is enabled)
FREEDOMPAY_PAYOUT_SECRET_KEY=
# Public callback URLs — must be HTTPS reachable from Freedom servers
FREEDOMPAY_RESULT_URL=http://localhost:8080/api/v1/webhooks/freedompay/result
FREEDOMPAY_PAYOUT_RESULT_URL=http://localhost:8080/api/v1/webhooks/freedompay/payout-result
FREEDOMPAY_SUCCESS_URL=http://localhost:5173/payment/confirmation
FREEDOMPAY_FAILURE_URL=http://localhost:5173/payment/failure
# Test mode forces FreedomPay to skip real card processing
FREEDOMPAY_TEST_MODE=1

# Platform fee percentage (charged on every successful payment, deducted from owner payout)
APP_PLATFORM_FEE_PERCENT=8

# SMS provider for phone verification — logging | mobizon | smsc
SMS_PROVIDER=logging
# Mobizon (https://mobizon.kz) — only required when SMS_PROVIDER=mobizon
MOBIZON_API_KEY=
MOBIZON_FROM=Ecopay
# Phone verification limits
APP_SMS_CODE_TTL_SECONDS=300
APP_SMS_RESEND_COOLDOWN_SECONDS=60
APP_SMS_MAX_ATTEMPTS_PER_HOUR=3
