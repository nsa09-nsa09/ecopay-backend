# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL — single source of truth for both postgres container and backend
POSTGRES_DB=ecopay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
# POSTGRES_HOST defaults to "postgres" (compose service name). Override only if using external DB.
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# Host port mapping for local docker-compose (not used in Dokploy)
POSTGRES_PORT_HOST=5432

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Field-level encryption for TELECOM identifiers (generate with: openssl rand -base64 32)
APP_SECURITY_FIELD_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# CORS allowed origins (comma-separated, no trailing slash)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting
APP_RATE_LIMIT_LOGIN_ATTEMPTS=5
APP_RATE_LIMIT_LOGIN_DURATION_MINUTES=15

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
